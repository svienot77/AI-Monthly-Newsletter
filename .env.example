# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Microsoft Graph API (Hotmail / Outlook sender)
# Register an app at https://portal.azure.com → App registrations
# Grant Mail.Send delegated permission, generate a refresh token via OAuth2
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=consumers
MICROSOFT_REFRESH_TOKEN=your-refresh-token
SENDER_NAME=AI Pulse
SENDER_EMAIL=you@hotmail.fr

# Default newsletter recipient (can be overridden per-send via the web form)
RECIPIENT_EMAIL=recipient@domain.com

# Day of month to send the scheduled newsletter (1 = 1st, 15 = 15th, etc.)
# Accepts integers or APScheduler cron expressions (e.g. "1,15" for twice a month)
NEWSLETTER_SCHEDULE_DAY=1

# Password required to submit the web form (set this in Railway Variables)
APP_PASSWORD=your-secret-password

# Telegram bot notifications (optional — leave blank to disable)
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
